[project]
name = "{project_name}"
# description = "Your project description"
logo = "/assets/logo.svg"
# base_url = "https://docs.example.com"
edit_url = "https://github.com/oxidoc-lab/oxidoc-docs/blob/main/docs"

[theme]
primary = "#3b82f6"
dark_mode = "system"

[routing.root]
homepage = "home.rdx"
# pages = ["about.rdx", "contact.rdx"]

[routing]
header_links = [
  { label = "Docs", href = "/docs" },
  { label = "Lib", href = "/lib" },
  { label = "API", href = "/api" },
]
navigation = [
  { path = "/docs", dir = "docs", groups = [
    { group = "Getting Started", pages = [
      "quickstart",
      "api-reference",
      "advanced",
    ] },
    { group = "Guides", pages = [
      "guides/styling",
      "guides/animations",
      "guides/internationalization",
    ] },
    { group = "Deployment", pages = [
      "deployment",
      "deployment/github-pages",
      "deployment/vercel",
      "deployment/netlify",
    ] },
  ] },
  { path = "/lib", dir = "lib", groups = [
    { group = "Library API", pages = [
      "index",
      "manual-api",
      "library-example",
    ] },
  ] },
  { path = "/api", openapi = "./openapi.yaml" },
]

# [versioning]
# default = "v1.0"  # Label for current docs in the version switcher
# Archive old versions:  oxidoc archive create v1.0
# List archives:         oxidoc archive list
# Delete an archive:     oxidoc archive delete v1.0

[search]
# semantic = true

[social]
github = "https://github.com/oxidoc-lab/oxidoc"
discord = "https://discord.gg/CGHU4TR7Zb"

[footer]
copyright_owner = "{project_name}"
# copyright_owner_url = "https://github.com/oxidoc-lab"
